---
import Layout from '../layouts/Layout.astro';

const resources = [
  {
    title: "Choose Boring Technology",
    author: "Dan McKinley",
    description: "The seminal talk on why you should pick proven, well-understood tools and spend your innovation tokens wisely.",
    url: "https://mcfunley.com/choose-boring-technology",
    type: "article",
  },
  {
    title: "Build or Adopt? Stop Building Your Own Plumbing",
    author: "Shawn Wildermuth",
    description: "Why building your own infrastructure is almost always the wrong call, and how to recognize when you're doing it.",
    url: "https://blog.wildermuth.com/2025/03/17/build-or-adopt--stop-building-your-own-plumbing/",
    type: "article",
  },
  {
    title: "Don't Reinvent the Wheel, Unless You Plan on Learning More About Wheels",
    author: "Jeff Atwood",
    description: "Challenges the blanket advice and offers a nuanced take on where reinvention helps and where it hurts.",
    url: "https://blog.codinghorror.com/dont-reinvent-the-wheel-unless-you-plan-on-learning-more-about-wheels/",
    type: "article",
  },
  {
    title: "Seven Deadly Sins of Programming",
    author: "Eric Gunnerson",
    description: "Sin #1: building custom data access layers instead of using mature, well-supported tools.",
    url: "https://blogs.msdn.microsoft.com/ericgu/2007/02/01/seven-deadly-sins-of-programming-sin-1/",
    type: "article",
  },
  {
    title: "Selecting Third-Party Libraries: The Practitioners' Perspective",
    author: "Academic study",
    description: "26 factors developers consider when choosing a library. A practical guide on when to build vs. buy.",
    url: "https://arxiv.org/abs/2005.12574",
    type: "article",
  },
  {
    title: "Build v/s Buy",
    author: "Todd Gardner",
    description: "A clear-headed walkthrough of how to make the build-or-buy decision without letting ego drive it.",
    url: "https://www.youtube.com/watch?v=wjcuhMXuULY",
    type: "talk",
  },
  {
    title: "Choose Boring Technology (talk)",
    author: "Dan McKinley",
    description: "The conference talk version of the famous essay, with worked examples and audience Q&A.",
    url: "https://boringtechnology.club/",
    type: "talk",
  },
  {
    title: "Making Better Build vs Buy Decisions",
    author: "Chris Bell",
    description: "Practical decision framework presented at LeadDev New York 2024.",
    url: "https://www.youtube.com/watch?v=sGOamUc0zM0",
    type: "talk",
  },
];

const articles = resources.filter(r => r.type === "article");
const talks = resources.filter(r => r.type === "talk");

// Featured items shown on the homepage teaser (exported for reuse isn't possible in Astro pages,
// so the homepage will define its own subset)
---

<Layout title="Community - Use What Works">
  <!-- Hero -->
  <section class="py-16 sm:py-20 px-4 sm:px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Community</h1>
      <p class="text-xl text-text-offset">
        Articles, talks, and discussions that shaped the Use What Works manifesto.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8">Articles</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {articles.map((resource) => (
          <a
            href={resource.url}
            target="_blank"
            rel="noopener"
            class="group p-6 bg-background-offset rounded-xl border border-border hover:border-primary transition-colors"
          >
            <h3 class="font-bold mb-1 group-hover:text-primary transition-colors">{resource.title}</h3>
            <p class="text-sm text-primary mb-3">{resource.author}</p>
            <p class="text-sm text-text-offset leading-relaxed">{resource.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Talks -->
  <section class="pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8">Talks</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {talks.map((resource) => (
          <a
            href={resource.url}
            target="_blank"
            rel="noopener"
            class="group p-6 bg-background-offset rounded-xl border border-border hover:border-primary transition-colors"
          >
            <h3 class="font-bold mb-1 group-hover:text-primary transition-colors">{resource.title}</h3>
            <p class="text-sm text-primary mb-3">{resource.author}</p>
            <p class="text-sm text-text-offset leading-relaxed">{resource.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gergely Orosz quote -->
  <section class="pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="p-8 bg-background-offset rounded-xl border border-border">
        <blockquote class="text-text-offset italic leading-relaxed">
          "For every dev who thinks 'I could build this $30/month SaaS myself instead of paying for it' &mdash; the best thing you can do IS to build it! You learn 1. How much work it is (just for the base case) 2. Edge cases the SaaS silently takes care of 3. The cost (+pain!) of maintenance"
        </blockquote>
        <p class="mt-4 text-sm font-semibold">Gergely Orosz</p>
      </div>
    </div>
  </section>

  <!-- Back + Discussion -->
  <section class="pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto flex items-center">
      <a href="/" class="inline-flex items-center text-primary hover:underline">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to home
      </a>
      <span class="mx-2 text-text-offset">|</span>
      <a
        href="https://github.com/orgs/UseWhatWorks/discussions/"
        target="_blank"
        rel="noopener"
        class="text-primary hover:underline"
      >
        Join the discussion
      </a>
    </div>
  </section>
</Layout>
