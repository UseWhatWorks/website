---
import Layout from '../../layouts/Layout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getEntry, getCollection } from 'astro:content';
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const manifestoEntries = await getCollection('manifesto');

  // Filter out index.md and only get role pages
  const rolePages = manifestoEntries.filter(entry =>
    entry.id !== 'index.md' && entry.data.emoji
  );

  return rolePages.map(entry => ({
    params: { slug: entry.id.replace('.md', '') },
  }));
}

const { slug } = Astro.params;
const content = await getEntry('manifesto', slug);
const { Content } = await content.render();

const discussionsPath = path.join(process.cwd(), 'src/data/discussions.yaml');
const discussionsFile = fs.readFileSync(discussionsPath, 'utf-8');
const allDiscussions = yaml.load(discussionsFile) as Record<string, Array<{ title: string; url: string }>>;
const discussions = allDiscussions[slug as string] || [];
---

<Layout title={`${content.data.title} - Use What Works`}>
  <!-- Hero -->
  <section class={`py-16 sm:py-20 px-4 sm:px-6 text-center bg-gradient-to-br ${content.data.gradient}`}>
    <div class="max-w-3xl mx-auto">
      <div class="text-6xl mb-6">{content.data.emoji}</div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        {content.data.title}
      </h1>
      <p class="text-xl text-text-offset mb-2">
        {content.data.tagline}
      </p>
	  <a href="#discussions" target="_blank" rel="noopener" class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:opacity-90 transition-opacity" data-astro-cid-j7pv25f6="">
Join the conversation
</a>
    </div>
  </section>

  <!-- Content -->
  <section class="pt-16 pb-8 px-4 sm:px-6">
    <article class="prose">
      <Content />
    </article>
  </section>

  <!-- Discussions -->
  {discussions.length > 0 && (
    <section id="discussions" class="px-4 sm:px-6 discussions">
      <div class="max-w-3xl mx-auto">
        <div>
          <h2 class="text-xl text-center text-primary font-semibold mb-6">Join the Conversation</h2>
          <div class="space-y-3">
            {discussions.map((discussion) => (
              <a
                href={discussion.url}
                target="_blank"
                rel="noopener"
                class="group flex items-start gap-3 p-4 rounded-lg border-l-3 border-primary/30 bg-background-offset hover:border-primary hover:bg-primary/5 transition-all"
              >
                <svg class="w-5 h-5 text-primary/50 group-hover:text-primary shrink-0 mt-0.5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
                </svg>
                <span class="text-sm text-text-offset group-hover:text-text transition-colors leading-snug">{discussion.title}</span>
                <svg class="w-4 h-4 text-text-offset/0 group-hover:text-primary shrink-0 mt-0.5 ml-auto transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
                </svg>
              </a>
            ))}
          </div>
          <a
            href="https://github.com/orgs/UseWhatWorks/discussions/new?category=general"
            target="_blank"
            rel="noopener"
            class="inline-flex items-start gap-1.5 mt-4 text-sm text-text-offset hover:text-primary transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15"/>
            </svg>
            Start a new discussion
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Back Link -->
  <section class="pb-16 pt-12 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex items-center">
        <a href="/" class="inline-flex items-center text-primary hover:underline">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to home
        </a>
        <ShareButtons
          url={`https://usewhatworks.org/for/${slug}`}
          text={`${content.data.title}: ${content.data.tagline}`}
          class="ml-auto"
        />
    </div>
  </section>
</Layout>

<style>
  .prose {
    @apply max-w-3xl mx-auto;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    @apply relative;
  }

  .prose :global(h1) {
    @apply text-3xl sm:text-4xl font-bold mb-6;
  }

  .prose :global(h2) {
    @apply text-2xl sm:text-3xl font-bold mt-12 mb-6;
  }

  .prose :global(h3) {
    @apply text-lg font-semibold text-primary mb-2 mt-8;
  }

  .prose :global(h4) {
    @apply text-base font-semibold mb-2 mt-6;
  }

  .prose :global(.heading-anchor) {
    @apply absolute no-underline opacity-0 transition-opacity;
    left: -0.8em;
    text-decoration: none !important;
  }

  .prose :global(h1:hover .heading-anchor),
  .prose :global(h2:hover .heading-anchor),
  .prose :global(h3:hover .heading-anchor),
  .prose :global(h4:hover .heading-anchor) {
    @apply opacity-50;
  }

  .prose :global(.heading-anchor:hover) {
    @apply opacity-100 !important;
  }

  .prose :global(.anchor-icon) {
    @apply text-primary;
  }

  .prose :global(p) {
    @apply text-text-offset leading-relaxed mb-4;
  }

  .prose :global(a:not(.discuss-link)) {
    @apply text-primary underline underline-offset-2 hover:decoration-primary transition-colors;
    text-decoration-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  .prose :global(a:not(.discuss-link):hover) {
    text-decoration-color: var(--color-primary);
  }

  .prose :global(.discuss-link) {
    @apply inline-flex items-center ml-2 text-text-offset hover:text-primary transition-colors no-underline align-middle;
  }

  .prose :global(.discuss-link svg) {
    @apply w-5 h-5;
    stroke-width: 2.5;
  }

  .prose :global(ul) {
    @apply space-y-2 text-text-offset my-6 list-disc pl-6;
  }

  .prose :global(ol) {
    @apply space-y-2 text-text-offset my-6 list-decimal pl-6;
  }

  .prose :global(li) {
    @apply leading-relaxed;
  }

  .prose :global(hr) {
    @apply border-border my-12;
  }

  .prose :global(blockquote) {
    @apply text-text-offset italic border-l-4 border-primary pl-6 my-6;
  }
  
   .discussions :global(h2) {
    @apply text-2xl sm:text-3xl font-bold mb-6;
  }
</style>
