---
import Layout from '../layouts/Layout.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { getEntry } from 'astro:content';
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';

// Load manifesto for roles and content
const manifesto = await getEntry('manifesto', 'index');
const roles = manifesto.data.roles || [];

// Load signatories
const signatoriesPath = path.join(process.cwd(), 'src/data/signatories.yaml');
const signatoriesFile = fs.readFileSync(signatoriesPath, 'utf-8');
const signatoriesData = yaml.load(signatoriesFile) as { signatories: Array<{
  name: string;
  url?: string;
  title?: string;
  org?: string;
  github?: string;
}> };

const realSignatories = signatoriesData.signatories || [];
const placeholder = { name: 'Your name here?', url: 'https://github.com/UseWhatWorks/website/issues/new?template=add-signature.yml', placeholder: true };
const signatories = [...realSignatories, placeholder];
const PAGE_SIZE = 15;
const firstPage = signatories.slice(0, PAGE_SIZE);

// Load resources
const resourcesPath = path.join(process.cwd(), 'src/data/resources.yaml');
const resourcesFile = fs.readFileSync(resourcesPath, 'utf-8');
const resourcesData = yaml.load(resourcesFile) as {
  articles: Array<{ title: string; author: string; url: string; featured?: boolean }>;
  talks: Array<{ title: string; author: string; url: string; featured?: boolean }>;
};
const allResources = [...(resourcesData.articles || []), ...(resourcesData.talks || [])];
const featured = allResources.filter(r => r.featured);
---

<Layout title="Use What Works - Choose proven solutions over building from scratch">
  <!-- Hero Section -->
  <section class="py-16 px-4 sm:px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-8">
        Use What <span class="text-primary">Works</span>
      </h1>
      <blockquote class="text-2xl sm:text-3xl text-text-offset italic max-w-3xl mx-auto leading-relaxed mb-8">
        Organizations should generally use existing, proven, and sustainable solutions to common problems rather than developing, maintaining, and running their own.
      </blockquote>
      <a
        href="https://github.com/orgs/UseWhatWorks/discussions/"
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:opacity-90 transition-opacity"
      >
        Join the discussion
      </a>
    </div>
  </section>

  <!-- Role Selection -->
  <section class="pb-16 pt-4 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
        Choose Your Path
      </h2>
      <p class="text-xl text-text-offset text-center mb-12 max-w-2xl mx-auto">
        Discover how Use What Works applies to your role and responsibilities.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {roles.map((role) => (
          <a
            href={role.link}
            class="role-card group relative overflow-hidden rounded-2xl p-8 bg-background-offset border border-border transition-all duration-300 hover:scale-105 hover:shadow-2xl flex flex-col"
          >
            <div class={`absolute inset-0 bg-gradient-to-br ${role.gradient} opacity-0 group-hover:opacity-10 transition-opacity duration-300`}></div>

            <div class="relative z-10 flex flex-col flex-1">
              <div class="text-6xl mb-4 transform group-hover:scale-110 transition-transform duration-300">
                {role.emoji}
              </div>

              <h3 class="text-2xl font-bold mb-2 min-h-[4rem] flex items-start group-hover:text-primary transition-colors">
                {role.title}
              </h3>

              <p class="text-sm font-semibold text-primary mb-4 opacity-80 min-h-[2.5rem]">
                {role.tagline}
              </p>

              <p class="text-text-offset leading-relaxed flex-1">
                {role.description}
              </p>

              <div class="mt-6 flex items-center text-primary font-semibold">
                Explore
                <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Teaser -->
  <section class="py-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-block w-12 h-0.5 bg-primary mb-6"></div>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3">Further Reading</h2>
        <p class="text-text-offset max-w-md mx-auto">Articles and talks that shaped Use What Works.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {featured.map((resource, i) => (
          <a
            href={resource.url}
            target="_blank"
            rel="noopener"
            class="reading-card group relative p-6 rounded-2xl border border-border bg-background-offset transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            <h3 class="font-bold text-sm leading-snug mb-2 group-hover:text-primary transition-colors duration-300">{resource.title}</h3>
            <p class="text-xs text-text-offset">{resource.author}</p>
            <svg class="w-4 h-4 absolute bottom-5 right-5 text-primary opacity-0 group-hover:opacity-60 transition-all duration-300 translate-y-1 group-hover:translate-y-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
            </svg>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/community" class="group inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline underline-offset-4">
          Explore the full collection
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Signatories Section -->
  <section id="sign" class="py-20 px-4 sm:px-6 bg-background-offset/50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-block w-12 h-0.5 bg-primary mb-6"></div>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3">Signatories</h2>
        <p class="text-text-offset">
          <span class="tabular-nums font-semibold text-text">{realSignatories.length}</span> {realSignatories.length === 1 ? 'person has' : 'people have'} signed this manifesto
        </p>
      </div>

      <ul id="signatories-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        {firstPage.map((person) => (
          person.placeholder ? (
            <li class="group p-4 rounded-xl border-2 border-dashed border-text-offset/30 hover:border-primary/50 transition-colors">
              <a
                href={person.url}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3"
              >
                <div class="w-9 h-9 rounded-full shrink-0 border-2 border-dashed border-text-offset/30 flex items-center justify-center">
                  <svg class="w-4 h-4 text-text-offset/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                </div>
                <div class="min-w-0">
                  <span class="block font-semibold text-sm text-text-offset italic">{person.name}</span>
                  <p class="text-xs text-text-offset/60 mt-0.5">Add your signature</p>
                </div>
              </a>
            </li>
          ) : (
            <li class="group p-4 rounded-xl bg-background border border-border hover:border-primary transition-colors">
              <div class="flex items-center gap-3">
                {person.github && (
                  <img
                    src={`https://github.com/${person.github}.png?size=64`}
                    alt=""
                    width="36"
                    height="36"
                    loading="lazy"
                    class="rounded-full shrink-0 ring-2 ring-border group-hover:ring-primary/30 transition-all duration-300"
                  />
                )}
                <div class="min-w-0">
                  {person.url ? (
                    <a
                      href={person.url}
                      target="_blank"
                      rel="noopener"
                      class="block font-semibold text-sm text-primary hover:underline underline-offset-2"
                    >
                      {person.name}
                    </a>
                  ) : (
                    <span class="block font-semibold text-sm">{person.name}</span>
                  )}
                  {(person.title || person.org) && (
                    <p class="text-xs text-text-offset mt-0.5">
                      {person.title}{person.title && person.org && ' at '}{person.org}
                    </p>
                  )}
                </div>
              </div>
            </li>
          )
        ))}
      </ul>

      {signatories.length > PAGE_SIZE && (
        <div id="signatories-paging" class="flex items-center justify-center gap-4 mb-14">
          <button id="sig-prev" disabled class="px-4 py-2 text-sm font-semibold rounded-lg border border-border hover:border-primary hover:text-primary disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
            Previous
          </button>
          <span id="sig-page-info" class="text-sm text-text-offset tabular-nums">
            Page 1 of {Math.ceil(signatories.length / PAGE_SIZE)}
          </span>
          <button id="sig-next" class="px-4 py-2 text-sm font-semibold rounded-lg border border-border hover:border-primary hover:text-primary disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
            Next
          </button>
        </div>
      )}

      <script is:inline define:vars={{ signatories, PAGE_SIZE }}>
        (function() {
          const grid = document.getElementById('signatories-grid');
          const prevBtn = document.getElementById('sig-prev');
          const nextBtn = document.getElementById('sig-next');
          const pageInfo = document.getElementById('sig-page-info');
          if (!grid || !prevBtn || !nextBtn || !pageInfo) return;

          const totalPages = Math.ceil(signatories.length / PAGE_SIZE);
          let currentPage = 1;

          function renderSignatory(person) {
            const li = document.createElement('li');

            if (person.placeholder) {
              li.className = 'group p-4 rounded-xl border-2 border-dashed border-text-offset/30 hover:border-primary/50 transition-colors';
              li.innerHTML = '<a href="' + person.url + '" target="_blank" rel="noopener" class="flex items-center gap-3">'
                + '<div class="w-9 h-9 rounded-full shrink-0 border-2 border-dashed border-text-offset/30 flex items-center justify-center">'
                + '<svg class="w-4 h-4 text-text-offset/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>'
                + '</div>'
                + '<div class="min-w-0">'
                + '<span class="block font-semibold text-sm text-text-offset italic">' + person.name + '</span>'
                + '<p class="text-xs text-text-offset/60 mt-0.5">Add your signature</p>'
                + '</div></a>';
              return li;
            }

            li.className = 'group p-4 rounded-xl bg-background border border-border hover:border-primary transition-colors';

            let avatarHtml = '';
            if (person.github) {
              avatarHtml = '<img src="https://github.com/' + person.github + '.png?size=64" alt="" width="36" height="36" loading="lazy" class="rounded-full shrink-0 ring-2 ring-border group-hover:ring-primary/30 transition-all duration-300" />';
            }

            let nameHtml = '';
            if (person.url) {
              nameHtml = '<a href="' + person.url + '" target="_blank" rel="noopener" class="block font-semibold text-sm text-primary hover:underline underline-offset-2">' + person.name + '</a>';
            } else {
              nameHtml = '<span class="block font-semibold text-sm">' + person.name + '</span>';
            }

            let detailHtml = '';
            if (person.title || person.org) {
              const detail = (person.title || '') + (person.title && person.org ? ' at ' : '') + (person.org || '');
              detailHtml = '<p class="text-xs text-text-offset mt-0.5">' + detail + '</p>';
            }

            li.innerHTML = '<div class="flex items-center gap-3">' + avatarHtml + '<div class="min-w-0">' + nameHtml + detailHtml + '</div></div>';
            return li;
          }

          function renderPage(page) {
            currentPage = page;
            const start = (page - 1) * PAGE_SIZE;
            const pageItems = signatories.slice(start, start + PAGE_SIZE);

            grid.innerHTML = '';
            pageItems.forEach(function(person) {
              grid.appendChild(renderSignatory(person));
            });

            pageInfo.textContent = 'Page ' + page + ' of ' + totalPages;
            prevBtn.disabled = page === 1;
            nextBtn.disabled = page === totalPages;

            grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }

          prevBtn.addEventListener('click', function() {
            if (currentPage > 1) renderPage(currentPage - 1);
          });

          nextBtn.addEventListener('click', function() {
            if (currentPage < totalPages) renderPage(currentPage + 1);
          });
        })();
      </script>

      <!-- CTA -->
      <div class="relative text-center p-10 sm:p-12 rounded-2xl border border-border bg-background overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/3 to-transparent"></div>
        <div class="relative">
          <h3 class="text-xl sm:text-2xl font-bold mb-3">Sign the Manifesto</h3>
          <p class="text-text-offset mb-8 max-w-sm mx-auto">
            Add your name by opening an issue on GitHub.
          </p>
          <a
            href="https://github.com/UseWhatWorks/website/issues/new?template=add-signature.yml"
            class="inline-block px-8 py-3.5 bg-primary text-white font-semibold rounded-xl hover:opacity-90 transition-all duration-200 hover:shadow-lg hover:shadow-primary/20"
          >
            Add Your Signature
          </a>
          <div class="mt-6 pt-5 border-t border-border">
            <p class="text-text-offset text-xs tracking-wide uppercase mb-3">or spread the word</p>
            <ShareButtons
              url="https://usewhatworks.org"
              text="Use What Works: Choose proven solutions over building from scratch."
              class="justify-center"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .role-card {
    backdrop-filter: blur(10px);
  }

  .reading-card {
    backdrop-filter: blur(4px);
  }
</style>
